# =============================================================================
# BlackBerry Radar + Supabase Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# -- Supabase ------------------------------------------------------------------
# Project URL (e.g. https://xyzproject.supabase.co)
# Local dev: http://127.0.0.1:54321
SUPABASE_URL=

# Service-role key (NOT the anon key — needed for server-side upserts/RLS bypass)
# Local dev: run `npx supabase status` to obtain the service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Anon key (used by the frontend via Vite)
# Local dev example (.env.local):
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_SUPABASE_ANON_KEY=<anon key from `npx supabase status`>
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -- Provar Integration --------------------------------------------------------
# These secrets are read by the `provar-pull` Edge Function. They MUST be
# configured in Supabase (Dashboard → Edge Functions → Secrets) — they are
# NOT Vite env vars and are NOT loaded from this file at runtime.
#
# Required Edge Function secrets:
#   PROVAR_API_KEY            — API key from Provar (sent as X-API-Key header)
#   SUPABASE_URL              — your Supabase project URL
#   SUPABASE_SERVICE_ROLE_KEY — service role key (server-side DB writes)
#
# Optional Edge Function secret:
#   ALLOWED_ORIGIN            — additional origin allowed for CORS
#                               (localhost:5173/5174 are always allowed)
#
# Set them via the Supabase CLI:
#   npx supabase secrets set PROVAR_API_KEY=your_provar_api_key
#   npx supabase secrets set SUPABASE_URL=https://YOUR_PROJECT.supabase.co
#   npx supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
#
# PROVAR_API_KEY=your_provar_api_key

# -- BlackBerry Radar API ------------------------------------------------------
# Base URL for the Radar REST API (include version path)
# Examples:
#   https://api.blackberry.com/radar/v1
#   https://radar.blackberry.com/api/v1
RADAR_API_BASE_URL=

# API client ID / key-id (used as JWT issuer and Bearer fallback)
RADAR_API_KEY=

# EC private key for JWT (ES256) authentication (optional if using plain Bearer)
# Paste the PEM with literal \n for newlines, e.g.:
# RADAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGH...base64...\n-----END PRIVATE KEY-----"
RADAR_PRIVATE_KEY=

# Or point to a PEM file instead of inlining the key:
# RADAR_PRIVATE_KEY_FILE=/path/to/private_key.pem

# -- Ingestion tuning (optional) -----------------------------------------------
# Page size for paginated API requests (default: 100)
# RADAR_PAGE_SIZE=100

# Maximum days of history to pull on first full sync (default: 365)
# RADAR_MAX_HISTORY_DAYS=365

# Batch size for Supabase upserts (default: 500)
# RADAR_BATCH_SIZE=500
